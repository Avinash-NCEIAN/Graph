This code is the generic code; there are other algorithms that can also solve it, like SCC,
*/


#include<bits/stdc++.h>
using namespace std;

int n,m;
vector<vector<int>>g;
vector<int>col;
vector<int>parent;
vector<int>cycle_path;
vector<int>cntcycle;
vector<int>prefix_order;
bool is_cycle = 0;

void dfs(int node,int par) {
	parent[node] = par;
	col[node] = 2;
	for(auto v:g[node]) {
		if(col[v] == 1) {
			dfs(v,node);
		} else if(col[v] == 2) {
			if(is_cycle == 0) {
				int temp = node;
				cycle_path.push_back(v);
				while(temp!=v) {
					cycle_path.push_back(temp);
					temp = parent[temp];
				}
				cycle_path.push_back(temp);//here: temp==v
			    reverse(cycle_path.begin(),cycle_path.end());
			}
			cntcycle[node]++;
			cntcycle[parent[v]]--;
			is_cycle = 1;
		}
	}
	col[node] = 3;
    prefix_order.push_back(node);
}

int main()
{
	cin>>n>>m;
	g.resize(n+1);
	col.assign(n+1,1);
	parent.assign(n+1,-1);
	cntcycle.assign(n+1,0);

	for(int i = 0; i<m; i++) {
		int x,y;
		cin>>x>>y;
		g[x].push_back(y);
	}

	for(int i = 1; i<=n && !is_cycle; i++) {
		if(col[i] == 1)dfs(i,0);
	}
	
// 	for(int i = 0; i<cycle_path.size(); i++) {
// 		cout<<cycle_path[i]<<" ";
// 	}	

	
	for(auto v:prefix_order){
	   // cout<<v<<" "<<endl;
	    cntcycle[parent[v]]+=cntcycle[v];
	}
	
	int cnt_node = 0;
	for(int i = 1;i<=n;i++){
	    if(cntcycle[i]>0)cnt_node++;
	}
	
	cout<<cnt_node;
	
	return 0;
}


