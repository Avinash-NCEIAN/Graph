#include<bits/stdc++.h>
using namespace std;

int n,m;
vector<vector<int>>g;
vector<int>topo;
vector<int>col;
vector<int>parent;
vector<int>cycle_path;
bool is_cycle = 0;

void dfs(int node,int par) {
    if(is_cycle)return ;
	parent[node] = par;
	col[node] = 2;
	for(auto v:g[node]) {
		if(col[v] == 1) {
			dfs(v,node);
			if(is_cycle)return ;
		} else if(col[v] == 2) {
			if(is_cycle == 0) {
				int temp = node;
				cycle_path.push_back(v);
				while(temp!=v) {
					cycle_path.push_back(temp);
					temp = parent[temp];
				}
				cycle_path.push_back(temp);//here: temp==v
			    reverse(cycle_path.begin(),cycle_path.end());
			}
			is_cycle = 1;
			return;
		}
	}
	col[node] = 3;

	topo.push_back(node);
}

int main()
{
	cin>>n>>m;
	g.resize(n+1);
	col.assign(n+1,1);
	parent.assign(n+1,-1);

	for(int i = 0; i<m; i++) {
		int x,y;
		cin>>x>>y;
		g[x].push_back(y);
	}

	for(int i = 1; i<=n && !is_cycle; i++) {
		if(col[i] == 1)dfs(i,0);
	}
	
	for(int i = 0; i<cycle_path.size(); i++) {
		cout<<cycle_path[i]<<" ";
	}
	
	return 0;
}
