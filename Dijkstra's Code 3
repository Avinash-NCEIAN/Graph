#include<bits/stdc++.h>
using namespace std;

int n,m;
vector<vector<pair<int,int>>> g;
vector<int> dist,vis;

class prioritiz{
    public: bool operator()(pair<int,int> &p1,pair<int,int> &p2){
        return p1.second>p2.second;
    }
};

void Dijkstra(int node) {
	priority_queue<pair<int,int>,vector<pair<int,int>>,greater<pair<int,int>>> pq;
	pq.push({0,node});
	dist[node] = 0;
	
	while(!pq.empty()) {
		pair<int,int> curr = pq.top();
		pq.pop();
        
        if(vis[curr.second])continue;
        vis[curr.second] = 1;
        
		for(auto v: g[curr.second]) {
		    int neigh = v.first;
		    int wt = v.second;
			if(dist[neigh]>dist[curr.second]+wt) {
				dist[neigh]=dist[curr.second]+wt;

			    pq.push({dist[neigh],neigh});
			}
		}
	}
}

int main()
{
	cin>>n>>m;
	g.resize(n+1);
	dist.assign(n+1,1e9);
	vis.assign(n+1,0);

	for(int i = 1; i<=m; i++) {
		int a,b,c;
		cin>>a>>b>>c;

		g[a].push_back({b,c});
		g[b].push_back({a,c});
	}

	int st = 1;
	Dijkstra(st);

	for(int i = 1; i<=n; i++) {
		cout<<i<<" "<<dist[i]<<endl;
	}
	return 0;
}


