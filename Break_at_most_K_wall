#include<bits/stdc++.h>
using namespace std;

using state = pair<pair<int,int>,int>;
#define F first
#define S second

const int INF = 100;
int dx[] = {1,0,-1,0};
int dy[] = {0,1,0,-1};

int n,m,k;
vector<vector<char>> g;
vector<vector<vector<int>>> vis,dist;

vector<state> neighbours(state curr) {
	vector<state> neigh;
	for(int dir = 0; dir<4; dir++) {
		int nx = dx[dir] + curr.F.F;
		int ny = dy[dir] + curr.F.S;
		if(nx>=0 && nx<n && ny>=0 && ny<m) {
			int nz = curr.S;
			if(g[nx][ny]=='#') nz++;

			if(nz<=k)
				neigh.push_back({{nx,ny},nz});
		}
	}

	return neigh;
}

void Brake_Wall(state st) {
	queue<state> q;
	q.push(st);
	dist[st.F.F][st.F.S][st.S] = 0;


	while(!q.empty()) {
		state curr = q.front();
		q.pop();
		if(vis[curr.F.F][curr.F.S][curr.S])continue;


		vis[curr.F.F][curr.F.S][curr.S] = 1;
		for(auto v: neighbours(curr)) {

			if(dist[v.F.F][v.F.S][v.S] > dist[curr.F.F][curr.F.S][curr.S]+1) {
				dist[v.F.F][v.F.S][v.S] = dist[curr.F.F][curr.F.S][curr.S]+1;
				q.push(v);
			}
		}

	}
}


int main()
{
	cin>>n>>m>>k;
	g.resize(n,vector<char>(m));
	vis.assign(n, vector<vector<int>>(m, vector<int>(k + 1, 0)));
	dist.assign(n, vector<vector<int>>(m, vector<int>(k + 1, INF)));


	state st,en;
	for(int i = 0; i<n; i++) {
		for(int j = 0; j<m; j++) {
			cin>>g[i][j];
			if(g[i][j] == 'S') {
				st = {{i,j},0};
			}

			if(g[i][j] == 'E') {
				en = {{i,j},0};
			}
		}
	}
	
	Brake_Wall(st);

	int ans = INF;

	for(int i = 0; i <= k; i++)
		ans = min(ans, dist[en.F.F][en.F.S][i]);

	if(ans == INF)
		cout << "NO\n";
	else {
		cout << "YES\n";
		cout << ans << "\n";
	}

	return 0;
}


