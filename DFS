#include<bits/stdc++.h>
using namespace std;
int n,m;
vector<vector<int>>g;
vector<bool> visited(n,false);

void dfs(int node){
    visited[node] = true;
    cout<<node<<" ";
    for(auto v: g[node]){
        if(!visited[v]){
            dfs(v);
        }
    }
}

int main()
{
    
    cin>>n>>m;
    
    visited.assign(n+1,false);
    //g.resize(n+1);
    g.assign(n + 1, vector<int>());
    for(int i = 1;i<=m;i++){
        int a,b;
        cin>>a>>b;
        g[a].push_back(b);
        g[b].push_back(a);
    }
    
    dfs(1);
    cout<<endl;
    for(int i = 0;i<visited.size();i++){
        cout<<visited[i]<<" ";
    }
    
    return 0;
}
