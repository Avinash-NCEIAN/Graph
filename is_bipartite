#include<bits/stdc++.h>
using namespace std;

vector<vector<int>> g;
vector<bool> vis;
vector<int> node_col;

bool is_bipartite = 1; 

void dfs(int node, int color){
    vis[node] = true;
    node_col[node] = color;
    
    for(auto v: g[node]){
        if(!vis[v]){
            dfs(v,3-color);
        }else if(node_col[v] == node_col[node]){
            is_bipartite = 0;
        }
    }
}

int main(){
    int n,m;
    cin>>n>>m;
    
    g.resize(n+1);
    vis.assign(n+1,false);
    node_col.resize(n+1,0);
    
    for(int i = 1;i<=m;i++){
        int x,y;
        cin>>x>>y;
        
        g[x].push_back(y);
        g[y].push_back(x);
    }
    
    int color = 1;
    for(int i = 1;i<=n;i++){
        if(!vis[i]){
            dfs(i,color);
        }
    }
    
    for(int i = 1;i<=n;i++){
        cout<<vis[i]<<" ";
    }
    
    cout<<endl;
    
    for(int i = 1;i<=n;i++){
        cout<<i<<" "<<node_col[i]<<endl;
    }
    
    if(is_bipartite){
        cout<<"Bipartite"<<endl;
    }else{
        cout<<"NO"<<endl;
    }
    
   
    
    return 0;
}
